<!DOCTYPE html>
<html>
<head>
  <title>Menu - FoodieHub</title>

  <style>

    body{
      margin:0;
      font-family:Arial, sans-serif;
      background:#f5f5f5;
    }

    .container{
      width:90%;
      margin:auto;
      padding:30px 0;
    }

    .heading{
      text-align:center;
      margin-bottom:40px;
    }

    .heading h1{
      font-size:40px;
      color:#333;
      margin-bottom:10px;
    }

    .heading p{
      color:gray;
      font-size:18px;
    }

    .menu-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:30px;
    }

    .food-card{
      background:white;
      border-radius:18px;
      overflow:hidden;
      box-shadow:0 5px 20px rgba(0,0,0,0.1);
      transition:0.3s;
    }

    .food-card:hover{
      transform:translateY(-8px);
      box-shadow:0 10px 25px rgba(0,0,0,0.15);
    }

    .food-card img{
      width:100%;
      height:220px;
      object-fit:cover;
    }

    .food-content{
      padding:18px;
    }

    .restaurant-name{
      color:#ff4d4d;
      font-size:14px;
      font-weight:bold;
      margin-bottom:8px;
    }

    .food-name{
      font-size:22px;
      font-weight:bold;
      color:#333;
      margin-bottom:8px;
    }

    .category{
      color:gray;
      margin-bottom:12px;
    }

    .price{
      font-size:20px;
      font-weight:bold;
      color:#111;
      margin-bottom:15px;
    }

    .btn{
      width:100%;
      padding:12px;
      border:none;
      border-radius:10px;
      background:#ff4d4d;
      color:white;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
    }

    .btn:hover{
      background:#e60000;
    }

  </style>
</head>

<body>

<%- include("partials/header") %>

<div class="container">

  <div class="heading">
    <h1>🍴 Explore Delicious Food</h1>
    <p>Order food from your favorite restaurants</p>
  </div>

  <div class="menu-grid">

    <% menuItems.forEach(item => { %>

      <div class="food-card">

        <img src="<%= item.image %>">

        <div class="food-content">

          <div class="restaurant-name">
            <%= item.restaurantName %>
          </div>

          <div class="food-name">
            <%= item.name %>
          </div>

          <div class="category">
            <%= item.category %>
          </div>

          <div class="price">
            ₹<%= item.price %>
          </div>

          <form action="/add-to-cart" method="POST">

            <input type="hidden" name="name" value="<%= item.name %>">

            <input type="hidden" name="price" value="<%= item.price %>">

            <input type="hidden" name="image" value="<%= item.image %>">

            <button class="btn" type="submit">
              Add To Cart 🛒
            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

</body>
</html>