<!DOCTYPE html>
<html>
<head>

  <title><%= restaurant.name %></title>

  <style>

    body{
      font-family:Arial;
      background:#f4f4f4;
      margin:0;
    }

    .hero{
      height:300px;
      background:url('<%= restaurant.image %>');
      background-size:cover;
      background-position:center;
    }

    .container{
      max-width:1100px;
      margin:auto;
      padding:30px;
    }

    .categories{
      display:flex;
      gap:15px;
      margin:20px 0;
      flex-wrap:wrap;
    }

    .cat{
      background:#ff4d4d;
      color:white;
      padding:10px 18px;
      border-radius:30px;
    }

    .menu-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
      gap:25px;
    }

    .food-card{
      background:white;
      border-radius:15px;
      overflow:hidden;
      box-shadow:0 5px 15px rgba(0,0,0,0.1);
    }

    .food-card img{
      width:100%;
      height:180px;
      object-fit:cover;
    }

    .food-content{
      padding:15px;
    }

    button{
      width:100%;
      padding:12px;
      border:none;
      background:#ff4d4d;
      color:white;
      border-radius:8px;
      cursor:pointer;
    }

  </style>

</head>

<body>

<div class="hero"></div>

<div class="container">

  <h1><%= restaurant.name %></h1>

  <p>
    ⭐ <%= restaurant.rating %> •
    🚚 <%= restaurant.deliveryTime %>
  </p>

  <div class="categories">

    <div class="cat">Pizza</div>
    <div class="cat">Burgers</div>
    <div class="cat">Drinks</div>
    <div class="cat">Desserts</div>
    <div class="cat">Indian</div>

  </div>

  <div class="menu-grid">

    <% restaurant.menu.forEach(item => { %>

      <div class="food-card">

        <img src="<%= item.image %>">

        <div class="food-content">

          <h3><%= item.name %></h3>

          <p>
            <%= item.category %>
          </p>

          <p>
            ₹<%= item.price %>
          </p>

          <form action="/add-to-cart" method="POST">

            <input type="hidden" name="name" value="<%= item.name %>">
            <input type="hidden" name="price" value="<%= item.price %>">
            <input type="hidden" name="image" value="<%= item.image %>">

            <button>
              Add to Cart
            </button>

          </form>

        </div>

      </div>

    <% }) %>

  </div>

</div>

</body>
</html>