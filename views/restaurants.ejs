<!DOCTYPE html>
<html>
<head>
  <title>Restaurants - FoodieHub</title>

  <style>

    body{
      font-family: Arial;
      background:#f5f5f5;
      margin:0;
    }

    .container{
      max-width:1200px;
      margin:auto;
      padding:30px;
    }

    h1{
      margin-bottom:30px;
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:25px;
    }

    .card{
      background:white;
      border-radius:15px;
      overflow:hidden;
      box-shadow:0 5px 15px rgba(0,0,0,0.1);
      transition:0.3s;
    }

    .card:hover{
      transform:translateY(-5px);
    }

    .card img{
      width:100%;
      height:220px;
      object-fit:cover;
    }

    .content{
      padding:15px;
    }

    .rating{
      color:green;
      font-weight:bold;
    }

    a{
      text-decoration:none;
      color:black;
    }

  </style>

</head>

<body>

<div class="container">

  <h1>🍴 Restaurants Near You</h1>

  <div class="grid">

    <% restaurants.forEach(r => { %>

      <a href="/restaurant/<%= r._id %>">

        <div class="card">

          <img src="<%= r.image %>">

          <div class="content">

            <h2><%= r.name %></h2>

            <p><%= r.cuisine %></p>

            <p class="rating">
              ⭐ <%= r.rating %>
            </p>

            <p>
              🚚 <%= r.deliveryTime %>
            </p>

          </div>

        </div>

      </a>

    <% }) %>

  </div>

</div>

</body>
</html>